# 本地开发
PORT=8787
APP_URL=http://localhost:8787
SESSION_SECRET=change-me-to-a-long-random-string
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:8787/api/auth/discord/callback
# 国内本地若 fetch failed，可设置代理：
# DISCORD_PROXY=http://127.0.0.1:7897

# Netlify 生产环境示例（在 Netlify 后台配置，不要提交 .env）：
# APP_URL=https://your-site.netlify.app
# DISCORD_REDIRECT_URI=https://your-site.netlify.app/api/auth/discord/callback
